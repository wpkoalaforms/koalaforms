{
  "title": "Event Registration",
  "settings": {
    "is_active": true,
    "success_message": "You are registered! A confirmation email has been sent to your inbox.",
    "admin_notification": true,
    "primary_email_field": "email"
  },
  "steps": [
    {
      "label": "Attendee Details",
      "next_label": "Next: Event Preferences",
      "columns": [
        [
          { "type": "text",  "label": "First Name",     "placeholder": "Jane",  "required": true },
          { "type": "text",  "label": "Last Name",      "placeholder": "Smith", "required": true }
        ],
        [
          { "type": "email", "label": "Email Address",  "required": true },
          { "type": "text",  "label": "Phone Number",   "placeholder": "+1 234 567 8900", "required": false }
        ]
      ],
      "fields": [
        { "type": "text",   "label": "Organisation / Company", "placeholder": "Acme Corp", "required": false },
        { "type": "text",   "label": "Job Title",              "placeholder": "e.g. Product Manager", "required": false },
        { "type": "url",    "label": "LinkedIn Profile",       "placeholder": "https://linkedin.com/in/", "required": false },
        {
          "type": "select",
          "label": "How did you hear about this event?",
          "required": false,
          "options": ["Email Newsletter", "Social Media", "Colleague / Friend", "Company Website", "Google Search", "Other"]
        }
      ]
    },
    {
      "label": "Event Preferences",
      "next_label": "Next: Accessibility",
      "prev_label": "Back",
      "fields": [
        {
          "type": "select",
          "label": "Ticket Type",
          "required": true,
          "options": ["General Admission (Free)", "VIP - $199", "Workshop Bundle - $299", "Student (with valid ID) - $49"]
        },
        {
          "type": "number",
          "label": "Number of Tickets",
          "required": true,
          "min": 1,
          "max": 10,
          "placeholder": "1"
        },
        {
          "type": "multiselect",
          "label": "Sessions you plan to attend",
          "required": false,
          "options": ["Opening Keynote", "Product Strategy Workshop", "Design Systems Panel", "Engineering Deep Dive", "Networking Lunch", "Closing Fireside Chat"]
        },
        {
          "type": "radio",
          "label": "Attendance Mode",
          "required": true,
          "options": ["In-person", "Virtual / Livestream"]
        },
        {
          "type": "select",
          "label": "T-Shirt Size",
          "required": false,
          "options": ["XS", "S", "M", "L", "XL", "XXL", "No thanks"]
        },
        {
          "type": "radio",
          "label": "Meal Preference",
          "required": true,
          "options": ["Standard", "Vegetarian", "Vegan", "Halal", "Kosher", "Gluten-free"]
        },
        { "type": "textarea", "label": "Topics you hope to learn about", "required": false, "placeholder": "e.g. AI, scaling products, design thinking...", "rows": 3 }
      ]
    },
    {
      "label": "Accessibility & Special Requirements",
      "next_label": "Next: Terms",
      "prev_label": "Back",
      "fields": [
        {
          "type": "multiselect",
          "label": "Accessibility Requirements",
          "required": false,
          "options": ["Wheelchair access", "Hearing loop", "Sign language interpreter", "Large print materials", "None required"]
        },
        { "type": "textarea", "label": "Other Special Requirements", "required": false, "placeholder": "Please describe any other requirements...", "rows": 4 },
        { "type": "text",     "label": "Emergency Contact Name",     "required": false, "placeholder": "Full name" },
        { "type": "text",     "label": "Emergency Contact Number",   "required": false, "placeholder": "+1 234 567 8900" }
      ]
    },
    {
      "label": "Terms & Confirmation",
      "next_label": "Complete Registration",
      "prev_label": "Back",
      "fields": [
        {
          "type": "disclosure",
          "label": "Event Terms & Conditions",
          "name": "event_terms",
          "required": true,
          "required_error": "You must accept the event terms to complete registration.",
          "check_label": "I have read and agree to the Event Terms and Conditions.",
          "content": "By registering for this event you agree to abide by our code of conduct. Tickets are non-refundable within 14 days of the event.<br><br>The organisers reserve the right to refuse entry or remove attendees who do not comply with event policies."
        },
        {
          "type": "disclosure",
          "label": "Photography & Recording Consent",
          "name": "photo_consent",
          "required": false,
          "required_error": "Please indicate your preference.",
          "check_label": "I consent to being photographed or recorded during the event for promotional purposes.",
          "content": "Photos and video recordings may be taken during the event for use in our marketing materials, website, and social media channels.<br><br>If you do not wish to be photographed, please notify a staff member on arrival."
        },
        { "type": "checkbox", "label": "I agree to receive event updates and communications via email.", "required": false }
      ]
    }
  ]
}
