    "subtype": {
      "type": "string",
      "default": ""
    },
    "hidden": {
      "type": "boolean",
      "default": false
    },
    "parent": {
      "type": "string",
      "default": ""
    },
    "usermeta": {
      "type": "string",
      "default": null
    }
