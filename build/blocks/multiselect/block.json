{
  "apiVersion": 3,
  "name": "Multiselect",
  "version": "0.1.0",
  "title": "Multi Choice",
  "icon": "edit",
  "description": "The Text element is a one-line text input field.",
  "attributes": {
    "inputLabel": {
      "type": "string",
      "default": ""
    },
    "name": {
      "type": "string",
      "default": ""
    },
    "value": {
      "type": "string",
      "default": ""
    },
    "readOnly": {
      "type": "boolean",
      "default": false
    },
    "required": {
      "type": "boolean",
      "default": false
    },
    "requiredError": {
      "type": "string",
      "default": null
    },
    "options": {
      "type": "array",
      "default": null
    },
    "displayMode": {
      "type": "string",
      "default": "vertical"
    },
    "displayOptions": {
      "type": "array",
      "default": [
        {
          "label": "Vertical",
          "value": "vertical"
        },
        {
          "label": "Horizontal",
          "value": "horizontal"
        }
      ]
    },
    "usermeta": {
      "type": "string",
      "default": null
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./index.css",
  "style": "file:./style-index.css"
}